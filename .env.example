OPENAI_API_KEY=your_key_here
# Structured CV parsing (JSON). Default: gpt-4o
# OPENAI_CV_MODEL=gpt-4o

# Google Gemini (fallback yoki faqat Gemini). AI Studio: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_CV_MODEL=gemini-2.5-flash
# CV_EXTRACT_PROVIDER=auto

DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production

# Default false = public API (no Authorization header / VITE_API_TOKEN needed). Writes use user "__anonymous_api__".
# Set true in production to require DRF Token or Session on all endpoints (except register/login).
# API_REQUIRE_AUTH=false

# Optional: extra allowed origins (comma-separated, no spaces needed). Local Vite/React ports are already in settings.
# Example for deployed frontend + PythonAnywhere:
# CORS_ALLOWED_ORIGINS=https://my-frontend.vercel.app,https://username.pythonanywhere.com
