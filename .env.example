# =============================================================================
# AI CV System — Environment Configuration
# Copy this file to .env and fill in your values.
# Place .env next to manage.py  (ai_cv_system/.env)
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production

# Auth — default TRUE (login required for all endpoints except register/login)
API_REQUIRE_AUTH=true

# ---------------------------------------------------------------------------
# AI / LLM Keys
# ---------------------------------------------------------------------------
# OpenAI — CV parsing + embeddings
OPENAI_API_KEY=your_openai_key_here
# OPENAI_CV_MODEL=gpt-4o

# Google Gemini — fallback if OpenAI quota exhausted
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_CV_MODEL=gemini-2.5-flash
# CV_EXTRACT_PROVIDER=auto   # auto | openai | gemini

# ---------------------------------------------------------------------------
# SMTP Email (Accept / Reject notifications to candidates)
# ---------------------------------------------------------------------------
# Backend: use smtp in production, console for local dev (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=AI CV System <your_email@gmail.com>

# Gmail note: use an App Password (Google Account → Security → App Passwords)
# if 2-Step Verification is enabled. Never use your main password.

# Other SMTP providers:
# Outlook / Office 365:  EMAIL_HOST=smtp.office365.com  EMAIL_PORT=587
# SendGrid:              EMAIL_HOST=smtp.sendgrid.net    EMAIL_PORT=587  EMAIL_HOST_USER=apikey
# Mailgun:               EMAIL_HOST=smtp.mailgun.org     EMAIL_PORT=587

# ---------------------------------------------------------------------------
# Frontend URL (used in email links)
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# CORS — Extra allowed origins (comma-separated)
# Local dev ports (3000, 5173) are already included in settings.py
# ---------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://my-frontend.vercel.app,https://username.pythonanywhere.com
